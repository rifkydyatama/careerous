// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  COUNSELOR
  ADMIN
}

enum PlanTier {
  FREE
  PREMIUM
}

// Konten 12 modul yang dapat dikelola admin (override metadata default di lib/modules.ts).
model ModuleContent {
  id         String    @id @default(uuid()) @db.Uuid
  number     Int       @unique
  title      String
  prompt     String    @db.Text
  phaseLabel String
  deadlineAt DateTime? // batas waktu absolut modul (tanggal & jam), diatur admin; null = tak ada
  updatedAt  DateTime  @updatedAt
}

// Pengaturan aplikasi global (singleton, id = "singleton").
// Saat ini: batas waktu (deadline) & durasi kunci modul, yang dapat diatur admin.
model AppSetting {
  id            String   @id
  deadlineHours Int      @default(48) // batas pengerjaan modul (jam)
  lockHours     Int      @default(72) // durasi kunci setelah telat kedua (jam)
  updatedAt     DateTime @updatedAt
}

// Institusi/sekolah. Langganan institusi memberi akses Premium ke seluruh siswanya.
model Institution {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String
  subscriptionActive    Boolean   @default(false)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  users                 User[]
}

enum LearningStyle {
  VISUAL
  AUDITORY
  KINESTHETIC
  READ_WRITE
  MULTIMODAL
}

enum JournalStatus {
  LOCKED
  UNLOCKED
  COMPLETED
}

model User {
  id              String            @id @default(uuid()) @db.Uuid
  name            String?
  email           String?           @unique
  passwordHash    String?
  role            UserRole          @default(STUDENT)
  plan            PlanTier          @default(FREE)
  institutionId   String?           @db.Uuid
  institution     Institution?      @relation(fields: [institutionId], references: [id])
  createdAt       DateTime          @default(now())
  assessments     Assessment[]
  journalProgress JournalProgress[]
  notifications   Notification[]

  // Relations for Counselors
  schedulesCreated CounselingSchedule[] @relation("CounselorSchedules")
  reportsCreated   ProgressReport[]     @relation("CounselorReports")

  // Relations for Students
  counselingBookings CounselingBooking[]       @relation("StudentBookings")
  progressReports    ProgressReport[]          @relation("StudentReports")
  careerReport       CareerExplorationReport?
}

model Assessment {
  id                  String        @id @default(uuid()) @db.Uuid
  studentId           String        @db.Uuid
  student             User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  riasecRealistic     Int
  riasecInvestigative Int
  riasecArtistic      Int
  riasecSocial        Int
  riasecEnterprising  Int
  riasecConventional  Int
  riasecTop3          String?
  learningStyle       LearningStyle
  createdAt           DateTime      @default(now())

  @@index([studentId])
}

model JournalProgress {
  id                String        @id @default(uuid()) @db.Uuid
  studentId         String        @db.Uuid
  student           User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekNumber        Int
  status            JournalStatus @default(LOCKED)
  reflectionText    String?
  evidenceImageUrl  String?
  counselorFeedback String?
  // Deadline tracking (sistem deadline modul)
  unlockedAt        DateTime? // saat modul terbuka (awal hitung 2 hari)
  deadlineAt        DateTime? // batas pengerjaan aktif
  lateCount         Int           @default(0) // berapa kali lewat deadline
  lockedUntil       DateTime? // waktu buka kembali bila terkunci 3 hari
  lateReason        String?       @db.Text // tugas transisi: alasan keterlambatan dari siswa
  lateMood          String?       // moodboard: perasaan siswa saat modul terlambat/terkunci (kunci dari MOOD_OPTIONS)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([studentId, weekNumber])
  @@index([studentId])
}

enum SessionType {
  INDIVIDUAL
  GROUP
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ScheduleStatus {
  AVAILABLE
  FULL
  COMPLETED
  CANCELLED
}

model CounselingSchedule {
  id          String         @id @default(uuid()) @db.Uuid
  counselorId String         @db.Uuid
  counselor   User           @relation("CounselorSchedules", fields: [counselorId], references: [id], onDelete: Cascade)
  type        SessionType    @default(INDIVIDUAL)
  maxCapacity Int            @default(1)
  startTime   DateTime
  endTime     DateTime
  status      ScheduleStatus @default(AVAILABLE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  bookings CounselingBooking[]

  @@index([counselorId])
}

model CounselingBooking {
  id         String             @id @default(uuid()) @db.Uuid
  scheduleId String             @db.Uuid
  schedule   CounselingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  studentId  String             @db.Uuid
  student    User               @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  topic      String             @db.Text
  status     BookingStatus      @default(PENDING)
  notes      String?            @db.Text // Counselor notes for this specific student after session
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([scheduleId, studentId])
  @@index([scheduleId])
  @@index([studentId])
}

model ProgressReport {
  id              String   @id @default(uuid()) @db.Uuid
  studentId       String   @db.Uuid
  student         User     @relation("StudentReports", fields: [studentId], references: [id], onDelete: Cascade)
  counselorId     String   @db.Uuid
  counselor       User     @relation("CounselorReports", fields: [counselorId], references: [id], onDelete: Cascade)
  title           String
  summary         String   @db.Text
  recommendations String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([counselorId])
}

model Notification {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String // DEADLINE_WARNING | MODULE_LOCKED | MODULE_REOPENED | CHECK_IN | REPORT_READY
  title            String
  body             String   @db.Text
  read             Boolean  @default(false)
  moduleNumber     Int?
  relatedStudentId String?  @db.Uuid // untuk notifikasi konselor: siswa terkait
  createdAt        DateTime @default(now())

  @@index([userId])
}

// Laporan eksplorasi karier otomatis (AI Insight). Saat ini di-generate rule-based (mock).
model CareerExplorationReport {
  id             String   @id @default(uuid()) @db.Uuid
  studentId      String   @unique @db.Uuid
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  summary        String   @db.Text
  dominantThemes String   @db.Text // CSV tema dominan
  sentimentLabel String // POSITIF | NETRAL | CAMPURAN
  sentimentScore Int // 0-100
  topInterest    String?
  isAiGenerated  Boolean  @default(false)
  generatedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
